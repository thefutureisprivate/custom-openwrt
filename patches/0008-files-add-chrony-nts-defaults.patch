From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: The future is private. <contact@thefutureisprivate.dev>
Date: Tue, 12 May 2026 19:20:00 +0200
Subject: [PATCH 8/10] files: add chrony NTS defaults

Add an OpenWrt files overlay for chrony-nts with authenticated NTS
sources and hardened runtime defaults based on the referenced chrony
configuration.

---
 files/etc/chrony/chrony.conf                |  23 ++++
 files/etc/config/chrony                     |  44 +++++++
 files/etc/uci-defaults/91-custom-chrony-nts |   7 ++
 files/usr/share/zoneinfo/leap-seconds.list  | 120 +++++++++++++++++++
 4 files changed, 194 insertions(+)
 create mode 100644 files/etc/chrony/chrony.conf
 create mode 100644 files/etc/config/chrony
 create mode 100755 files/etc/uci-defaults/91-custom-chrony-nts
 create mode 100644 files/usr/share/zoneinfo/leap-seconds.list

diff --git a/files/etc/chrony/chrony.conf b/files/etc/chrony/chrony.conf
new file mode 100644
index 0000000000..31d520d69d
--- /dev/null
+++ b/files/etc/chrony/chrony.conf
@@ -0,0 +1,23 @@
+# Load UCI-generated NTS sources.
+confdir /var/etc/chrony.d
+
+# Keep DHCP NTP support available when enabled in UCI.
+sourcedir /var/run/chrony-dhcp
+
+minsources 3
+authselectmode require
+leapseclist /usr/share/zoneinfo/leap-seconds.list
+dscp 46
+
+# State files live on tmpfs on OpenWrt.
+driftfile /var/run/chrony/drift
+dumpdir /var/run/chrony
+ntsdumpdir /var/run/chrony
+
+# Step only during early synchronization.
+makestep 1.0 3
+rtcsync
+
+# Disable remote chronyc and client access logging.
+cmdport 0
+noclientlog
diff --git a/files/etc/config/chrony b/files/etc/config/chrony
new file mode 100644
index 0000000000..50a75ad83d
--- /dev/null
+++ b/files/etc/config/chrony
@@ -0,0 +1,44 @@
+config server
+	option hostname 'time.cloudflare.com'
+	option iburst '1'
+	option nts '1'
+
+config server
+	option hostname 'ntppool1.time.nl'
+	option iburst '1'
+	option nts '1'
+
+config server
+	option hostname 'nts.netnod.se'
+	option iburst '1'
+	option nts '1'
+
+config server
+	option hostname 'ptbtime1.ptb.de'
+	option iburst '1'
+	option nts '1'
+
+config server
+	option hostname 'time.dfm.dk'
+	option iburst '1'
+	option nts '1'
+
+config server
+	option hostname 'time.cifelli.xyz'
+	option iburst '1'
+	option nts '1'
+
+config dhcp_ntp_server 'dhcp_ntp_server'
+	option iburst '1'
+	option disabled '1'
+
+config makestep 'makestep'
+	option threshold '1.0'
+	option limit '3'
+
+config nts 'nts'
+	option rtccheck '1'
+	option systemcerts '1'
+
+#config logging 'logging'
+#	option logchange '0.01'
diff --git a/files/etc/uci-defaults/91-custom-chrony-nts b/files/etc/uci-defaults/91-custom-chrony-nts
new file mode 100755
index 0000000000..2150f1d677
--- /dev/null
+++ b/files/etc/uci-defaults/91-custom-chrony-nts
@@ -0,0 +1,7 @@
+#!/bin/sh
+
+/etc/init.d/sysntpd disable 2>/dev/null || true
+/etc/init.d/sysntpd stop 2>/dev/null || true
+/etc/init.d/chronyd enable 2>/dev/null || true
+
+exit 0
